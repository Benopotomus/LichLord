BEGIN_OPTIONS
	ShaderName "DWD/Add Tex Opaque"
	Workflow "Unlit"
	Fallback "Diffuse" 
END_OPTIONS

BEGIN_PROPERTIES
	[Toggle] _ZWrite("ZWrite", float) = 1.0
	[HDR] _Color ("Main Color", Color) = (0, 1, 0, 1)
	[NoScaleOffset] _BaseTex("Base Tex", 2D) = "white" {}
END_PROPERTIES

BEGIN_CBUFFER
	half4 _Color;
END_CBUFFER

BEGIN_PASS("All")
	ZWrite [_ZWrite]
	Blend One One
	Cull Back
	ZTest LEqual
END_PASS


BEGIN_CODE

	TEXTURE2D(_BaseTex);
	SAMPLER(sampler_BaseTex);

	void SurfaceFunction(inout Surface o, ShaderData d)
	{
		half4 result = SAMPLE_TEXTURE2D(_BaseTex, sampler_BaseTex, d.texcoord0.xy) * _Color;
		o.Albedo = result.rgb;
		o.Alpha = 1.0;
	}

END_CODE

