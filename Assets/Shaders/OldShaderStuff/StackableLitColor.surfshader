BEGIN_OPTIONS
	Workflow "Metallic"
END_OPTIONS

BEGIN_PROPERTIES
	[HDR] _Color ("Main Color", Color) = (0, 1, 0, 1)
END_PROPERTIES

BEGIN_CBUFFER
	half4 _Color;
END_CBUFFER


BEGIN_CODE

	void SurfaceFunction(inout Surface o, ShaderData d)
	{
		o.Albedo = _Color.rgb;
		o.Alpha = 1.0;
	}

END_CODE

